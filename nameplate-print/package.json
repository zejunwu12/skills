  "main": "scripts/generate_groups.js",
  "bin": {
    "nameplate-print": "scripts/generate_groups.js"
  },
  "scripts": {
    "example": "node examples/basic-usage.js"
  },
  "keywords": [
    "nameplate",
    "group-sign",
    "docx",
    "print",
    "trae-skill",
    "名牌",
    "打印"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "docx": "^9.6.1"
  }
}